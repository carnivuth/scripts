# homelab
Host torterra
  hostname torterra.carnivuth.org
  User matteo
  IdentityFile ~/.ssh/homelab_key
  DynamicForward 40034

Host *.local.carnivuth.org
  User root
  ProxyJump torterra
  ServerAliveInterval=15
  IdentityFile ~/.ssh/homelab_key

# hetzner storage box for backups
Host u425518.your-storagebox.de storagebox
  HostName u425518.your-storagebox.de
  User u425518
  Port 23
  IdentityFile ~/.ssh/hetzner_key
